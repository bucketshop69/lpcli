{
  "name": "@lpcli/monitor",
  "version": "0.1.0",
  "type": "module",
  "description": "Watcher engine for LPCLI — RSI, price, funding rate, and pool alerts with automated actions",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "node --import tsx --test tests/engine.unit.ts",
    "test:e2e": "node --import tsx --test tests/monitor.e2e.ts"
  },
  "dependencies": {
    "@lpcli/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
