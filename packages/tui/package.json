{
  "name": "@lpcli/tui",
  "version": "0.1.0",
  "type": "module",
  "description": "Chat-first terminal UI for lpcli — Ink REPL shell",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "dev": "node --import tsx src/index.tsx"
  },
  "dependencies": {
    "@lpcli/core": "workspace:*",
    "@lpcli/monitor": "workspace:*",
    "ink": "^5.1.0",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/react": "^18.3.18",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
