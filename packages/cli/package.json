{
  "name": "@lpcli/cli",
  "version": "0.1.0",
  "type": "module",
  "description": "CLI for LPCLI — terminal interface for Meteora DLMM",
  "bin": {
    "lpcli": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test:e2e": "pnpm --filter @lpcli/core build && pnpm build && node --import tsx --test tests/*.e2e.ts",
    "dev": "node --import tsx src/index.ts"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@lpcli/core": "workspace:*",
    "@lpcli/monitor": "workspace:*",
    "@lpcli/tui": "workspace:*",
    "ink": "^5.1.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.18",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
