{
  "name": "@lpcli/core",
  "version": "0.1.0",
  "type": "module",
  "description": "Core SDK for LPCLI — Meteora DLMM pool discovery, scoring, and position management",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "node --import tsx --test tests/wallet.unit.ts",
    "test:e2e": "node --import tsx --test tests/core.e2e.ts",
    "test:e2e:funding": "node --import tsx --test tests/funding.e2e.ts",
    "test:e2e:swap": "node --import tsx --test tests/swap.e2e.ts",
    "test:e2e:open": "node --import tsx --test tests/open.e2e.ts",
    "test:e2e:close": "node --import tsx --test tests/close.e2e.ts",
    "test:e2e:roundtrip": "node --import tsx --test tests/roundtrip.e2e.ts",
    "dev": "node --import tsx --watch tests/core.e2e.ts"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.30.0",
    "@meteora-ag/dlmm": "1.9.4",
    "@open-wallet-standard/core": "^1.2.0",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.95.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
