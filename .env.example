# LPCLI Configuration
# Copy this file to .env and fill in your values

# Solana RPC — use Helius for mainnet (get key at https://helius.xyz)
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY_HERE

# Network: mainnet | devnet
CLUSTER=mainnet

# Wallet private key (base58 encoded) OR path to keypair file
# Example (base58): PRIVATE_KEY=5A...Z
# Example (file path): PRIVATE_KEY=~/.config/solana/id.json
PRIVATE_KEY=~/.config/solana/id.json

# Helius API key (for priority fee estimation)
HELIUS_API_KEY=YOUR_KEY_HERE

# Anthropic API key (optional — only needed for chat mode)
ANTHROPIC_API_KEY=YOUR_KEY_HERE

# Telegram bot token (optional — only needed for chat mode via direct bot)
TELEGRAM_BOT_TOKEN=YOUR_TOKEN_HERE
