# LPCLI user-space environment
# Copy to ~/.config/lpcli/.env if you need local overrides.
# Do not commit real RPC URLs or secrets.

# Solana RPC — use a private provider for production usage.
RPC_URL=https://api.mainnet-beta.solana.com

# Optional read-only RPC override. Defaults to RPC_URL.
# READ_RPC_URL=https://api.mainnet-beta.solana.com

# Network: mainnet | devnet
CLUSTER=mainnet

# OWS wallet name. lpcli init creates/uses this wallet by default.
OWS_WALLET=lpcli

# Funding token overrides. Defaults to USDC mainnet.
# FUNDING_TOKEN_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
# FUNDING_TOKEN_SYMBOL=USDC
# FUNDING_TOKEN_DECIMALS=6

# SOL reserved for transaction fees. Default: 0.08
FEE_RESERVE_SOL=0.08
